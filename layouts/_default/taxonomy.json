{
    "title": "{{ .Title }}",
    "type": "taxonomy",
    "url": "{{ .Permalink }}",
    "pages": [
        {{ range $index, $page := .Pages }}
            {{ if $index }},{{ end }}
            {
                "title": "{{ $page.Title }}",
                "url": "{{ $page.RelPermalink }}",
                "date": "{{ $page.Date.Format "2006-01-02" }}",
                "description": "{{ $page.Description }}"
            }
        {{ end }}
    ]
}
